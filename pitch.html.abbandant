      <div data-a data-d="3" style="display:grid; grid-template-columns:auto 1fr; gap:18px; background:rgba(56,189,248,0.05); border:1px solid rgba(56,189,248,0.3); border-radius:16px; padding:clamp(20px,3vh,32px) clamp(20px,2.5vw,32px); align-items:start; width:100%;">
